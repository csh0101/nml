<小说项目 名称="测试项目" 版本="2.1-M1">
  <元数据 />
  <设定集>
    <角色 id="char_a" 姓名="甲"/>
    <地点 id="loc_a" 名称="荒庙"/>
  </设定集>
  <正文>
    <章节 序号="1" 标题="段功能起始告警">
      <场景 id="s1" 地点引用="loc_a" 视角角色="char_a">
        <任务 目标="测试段功能起始"/>
        <段落计划 流转校验="开启">
          <段 序号="1" 字数目标="100" 功能="爆发" 焦点="动作" 节奏="快">
            <信息点 类型="冲突" 权重="5">爆发</信息点>
          </段>
        </段落计划>
      </场景>
    </章节>
  </正文>
</小说项目>
